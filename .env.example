# Plantilla de variables de entorno del FRONTEND.
# Copiala como .env.local y completá con los datos de tu proyecto de Supabase
# (Dashboard → Settings → API). El archivo .env.local no se sube a git.
#
# Solo van acá las variables que empiezan con VITE_: son las únicas que Vite
# le pasa al navegador.
#
# OJO: la API key de OpenRouter NO va en este archivo. Es un secreto del
# backend y se carga ejecutando en la terminal:
#     supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-ANON-KEY
